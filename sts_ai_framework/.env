STS_API_BASE_URL=http://localhost:5000
# 默认模型 (如果没有在命令行指定)
LLM_MODEL=gpt-4o

# ==========================================
# API Key 配置区域
# 请填入你拥有的 API Key，取消注释 (删除行首的 #) 并替换 ... 部分
# ==========================================

# --- OpenAI (ChatGPT) ---
# 模型: gpt-4o, gpt-4-turbo, gpt-3.5-turbo
OPENAI_API_KEY=sk-proj-...

# --- Anthropic (Claude) ---
# 模型: claude-3-opus-20240229, claude-3-sonnet-20240229, claude-3-haiku-20240307
# ANTHROPIC_API_KEY=sk-ant-...

# --- Google (Gemini) ---
# 模型: gemini/gemini-pro, gemini/gemini-1.5-pro
# GEMINI_API_KEY=...

# --- DeepSeek (深度求索) ---
# 模型: deepseek/deepseek-chat, deepseek/deepseek-coder
DEEPSEEK_API_KEY=sk-4710ae8c7a7a49ceb34d0289f7048f92

# --- Moonshot (Kimi / 月之暗面) ---
# 模型: moonshot/moonshot-v1-8k, moonshot/moonshot-v1-32k
# 需要显式设置 API Base，否则 litellm 可能找不到正确地址
MOONSHOT_API_BASE=https://api.moonshot.cn/v1
MOONSHOT_API_KEY=sk-3fWuf5TuK5kyvbtehSLGE6mCAlcLVg9xrDuhq32cdejZF03o

# --- ZhipuAI (智谱 GLM) ---
# 模型: zhipu/glm-4, zhipu/glm-4-flash
# ZHIPUAI_API_KEY=...

# --- Alibaba (通义千问 / Qwen) ---
# 模型: qwen/qwen-turbo, qwen/qwen-plus
# DASHSCOPE_API_KEY=...

# --- 01.AI (零一万物 / Yi) ---
# 模型: yi/yi-34b-chat-0205, yi/yi-large
# YI_API_KEY=...

# --- Local (Ollama) ---
# 如果使用本地 Ollama，不需要 Key，通常只需要指定 base_url
# 模型: ollama/llama3
# OLLAMA_API_BASE=http://localhost:11434
